@prefix : <http://example.org/aec-drawing-ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

<http://example.org/aec-drawing-ontology>
  a owl:Ontology ;
  owl:versionInfo "1.0" .

:TestClass
  a owl:Class ;
  rdfs:label "Test Class"@en ;
  rdfs:label "Classe de Test"@fr ;
  rdfs:label "Classe di Test"@it .

:TestProperty
  a owl:ObjectProperty ;
  rdfs:label "Test Property"@en ;
  rdfs:label "Propriété de Test"@fr .
