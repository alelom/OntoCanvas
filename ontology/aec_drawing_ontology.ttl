    :labellableRoot true .

:Orientation a owl:Class ;
    rdfs:label "Orientation" ;
    rdfs:comment "Can be standalone label - drawing orientation" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :DrawingSheet ] ;
    :labellableRoot true .

:Annotation a owl:Class ;
    rdfs:label "Annotation" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :Layout ] ;
    :labellableRoot true .

:DrawingType a owl:Class ;
    rdfs:label "Drawing type" ;
    rdfs:comment "Type of drawing view" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :Layout ] ;
    :labellableRoot true .

:Section a owl:Class ;
    rdfs:label "Section" ;
    rdfs:subClassOf :DrawingType ;
    :labellableRoot true .

:Elevation a owl:Class ;
    rdfs:label "Elevation" ;
    rdfs:subClassOf :DrawingType ;
    :labellableRoot true .

:Plan a owl:Class ;
    rdfs:label "Plan" ;
    rdfs:subClassOf :DrawingType ;
    :labellableRoot true .

:Perspective a owl:Class ;
    rdfs:label "Perspective" ;
    rdfs:subClassOf :DrawingType ;
    :labellableRoot true .

:DrawingContent a owl:Class ;
    rdfs:label "Drawing content" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :Layout ] ;
    :labellableRoot true .

:DetailLocation a owl:Class ;
    rdfs:label "Detail location" ;
    rdfs:subClassOf :DrawingContent ;
    :labellableRoot true .

:Typical a owl:Class ;
    rdfs:label "Typical" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:SlabEdge a owl:Class ;
    rdfs:label "Slab edge" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:Base a owl:Class ;
    rdfs:label "Base" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:Head a owl:Class ;
    rdfs:label "Head" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:SingleSystem a owl:Class ;
    rdfs:label "Single system" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:Corner a owl:Class ;
    rdfs:label "Corner" ;
    rdfs:subClassOf :DetailLocation ;
    :labellableRoot true .

:Interface a owl:Class ;
    rdfs:label "Interface" ;
    rdfs:subClassOf :DrawingContent ;
    :labellableRoot true .

:GA a owl:Class ;
    rdfs:label "GA (General Arrangement)" ;
    rdfs:comment "General arrangement drawing" ;
    :labellableRoot true .

:Detail a owl:Class ;
    rdfs:label "Detail" ;
    rdfs:comment "Detail drawing" ;
    :labellableRoot true .

