@prefix : <http://example.org/aec-drawing-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# =============================================================================
# AEC Drawing Ontology - Rev02 (from 250523_Ontology_schema_rev02.pdf)
# Covers: Drawing sheets, Facade systems, Structural components, General properties
# =============================================================================

:Ontology a owl:Ontology ;
    rdfs:label "AEC Drawing Ontology" ;
    rdfs:comment "Ontology for AEC drawing elements - facade, structural, and drawing metadata. Based on schema rev02 (06.04.23)." .

# =============================================================================
# OBJECT PROPERTIES (Relationships)
# =============================================================================

:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:comment "Direct containment or has-part relationship" ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:partOf a owl:ObjectProperty ;
    rdfs:label "part of" ;
    rdfs:comment "Entity is part of another entity" ;
    owl:inverseOf :contains ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:subsetOf a owl:ObjectProperty ;
    rdfs:label "subset of" ;
    rdfs:comment "Classification or sub-typing relationship" ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:hasProperty a owl:ObjectProperty ;
    rdfs:label "has property" ;
    rdfs:comment "Entity is characterized by a property" ;
    rdfs:domain owl:Thing ;
    rdfs:range owl:Thing .

:hasFunction a owl:ObjectProperty ;
    rdfs:label "has function" ;
    rdfs:comment "Entity has a functional property" ;
    rdfs:domain :FacadeComponent ;
    rdfs:range :Function .

:hasMaterial a owl:ObjectProperty ;
    rdfs:label "has material" ;
    rdfs:comment "Entity has a material property" ;
    rdfs:domain :FacadeComponent ;
    rdfs:range :Material .

# =============================================================================
# ANNOTATION PROPERTIES
# =============================================================================
# labellableRoot: from ontology diagram - solid contour = labellable, dashed = non-labellable
# =============================================================================

:labellableRoot a owl:AnnotationProperty ;
    rdfs:label "Labellable root" ;
    rdfs:comment "When true, this class can be used as a label by annotators (solid contour in diagram). When false, non-labellable (dashed contour)." .

# =============================================================================
# TOP-LEVEL ENTITIES (Red boxes - main concepts)
# =============================================================================
# Hierarchy: DrawingSheet contains Layout(s); Layout contains DrawingElement(s);
#            DrawingElement can be FacadeSystem or FacadeComponent
# =============================================================================

:DrawingSheet a owl:Class ;
    rdfs:label "Drawing sheet" ;
    rdfs:comment "Top-level container for a drawing. Contains Layout(s)." ;
    :labellableRoot true .

:DrawingElement a owl:Class ;
    rdfs:label "Drawing element" ;
    rdfs:comment "Element depicted on a drawing. Contained by Layout. Can be a Facade system or Facade component." ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :Layout ] ;
    :labellableRoot true .

:Layout a owl:Class ;
    rdfs:label "Layout" ;
    rdfs:comment "Drawing layout - contained by DrawingSheet. Contains DrawingElement(s), annotations, drawing type, and content." ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :DrawingSheet ] ;
    :labellableRoot true .

:FacadeSystem a owl:Class ;
    rdfs:label "Facade system" ;
    rdfs:comment "Facade system - part of support type; a type of drawing element" ;
    rdfs:subClassOf :DrawingElement ;
    :labellableRoot true .

:FacadeComponent a owl:Class ;
    rdfs:label "Facade component" ;
    rdfs:comment "Component of a facade system; a type of drawing element" ;
    rdfs:subClassOf :DrawingElement ;
    :labellableRoot true .

:PanelComponent a owl:Class ;
    rdfs:label "Panel component" ;
    rdfs:comment "Element category - panel-type facade component" ;
    rdfs:subClassOf :FacadeComponent ;
    :labellableRoot true .

:LinearComponent a owl:Class ;
    rdfs:label "Linear component" ;
    rdfs:comment "Element category - linear facade component" ;
    rdfs:subClassOf :FacadeComponent ;
    :labellableRoot true .

:PointComponent a owl:Class ;
    rdfs:label "Point component" ;
    rdfs:comment "Element category - point-type facade component" ;
    rdfs:subClassOf :FacadeComponent ;
    :labellableRoot true .

:StructuralComponent a owl:Class ;
    rdfs:label "Structural component" ;
    rdfs:comment "Structural component - part of support type" ;
    :labellableRoot true .

:SupportType a owl:Class ;
    rdfs:label "Support type" ;
    rdfs:comment "Support type - contains facade and structural systems" ;
    :labellableRoot true .

# =============================================================================
# DRAWING SHEET - Metadata, Orientation, Layout (Pink/Green/Blue boxes)
# =============================================================================

:Metadata a owl:Class ;
    rdfs:label "Metadata" ;
    rdfs:comment "Can be standalone label - drawing metadata" ;
    rdfs:subClassOf [ a owl:Restriction ; owl:onProperty :partOf ; owl:someValuesFrom :DrawingSheet ] ;
    :labellableRoot true .

:Titleblock a owl:Class ;
    rdfs:label "Titleblock" ;
    rdfs:subClassOf :Metadata ;
    :labellableRoot true .

:Note a owl:Class ;
    rdfs:label "Note" ;
    rdfs:subClassOf :Metadata ;
    :labellableRoot false .

:TextualNote a owl:Class ;
    rdfs:label "Textual note" ;
    rdfs:subClassOf :Note ;
    :labellableRoot false .

:Legend a owl:Class ;
