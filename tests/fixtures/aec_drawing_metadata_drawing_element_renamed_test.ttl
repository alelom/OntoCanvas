@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <http://example.org/aec-drawing-ontology#> .

@prefix owl: <http://www.w3.org/2002/07/owl#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix aec: <http://example.org/aec-drawing-ontology#>.
@prefix nam: <http://www.w3.org/XML/1998/namespace#>.
@prefix w: <https://w3id.org/>.
# Created/edited with https://alelom.github.io/OntoCanvas/ version 1.11.0

aec:AddOn
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Add-on";
    rdfs:subClassOf aec:FrameType.
aec:Aesthetic
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Aesthetic";
    rdfs:subClassOf aec:Function.
aec:Airtightness
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Airtightness";
    rdfs:subClassOf aec:Function.
aec:Aluminium
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Aluminium";
    rdfs:subClassOf aec:Material.
aec:Asymmetrical
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Asymmetrical";
    rdfs:subClassOf aec:Symmetry.
aec:BackingWall
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Backing wall";
    rdfs:subClassOf aec:PanelComponent.
aec:Base
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Base";
    rdfs:subClassOf aec:DetailLocation.
aec:Beam
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Beam";
    rdfs:subClassOf aec:StructuralMember.
aec:Blockwork
a owl:Class; rdfs:label "Blockwork"; rdfs:subClassOf aec:RoofCladding.
aec:Board
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Board";
    rdfs:subClassOf aec:PanelComponent.
aec:Bracket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Bracket";
    rdfs:subClassOf aec:PointComponent.
aec:BreatherMembrane
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Breather";
    rdfs:subClassOf aec:Membrane.
aec:Brick
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Brick";
    rdfs:subClassOf aec:FacingMaterial.
aec:Cable
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Cable";
    rdfs:subClassOf aec:LinearStructuralComponent.
aec:Capped
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Capped";
    rdfs:subClassOf aec:GlazingRetention.
aec:Capping
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Capping";
    rdfs:subClassOf aec:LinearComponent.
aec:CastInChannel
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Cast-in channel";
    rdfs:subClassOf aec:Fixing.
aec:CavityBarrier
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Cavity barrier";
    rdfs:subClassOf aec:Gasket.
aec:CavityWallSystem
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Cavity wall system";
    rdfs:subClassOf aec:FacadeSystem.
aec:Cementboard
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Cementboard";
    rdfs:subClassOf aec:Board.
aec:Channel
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Channel";
    rdfs:subClassOf aec:Gasket.
aec:ChordBracing
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Chord/bracing";
    rdfs:subClassOf aec:StructuralMember.
aec:CHS
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "CHS";
    rdfs:subClassOf aec:SectionShape.
aec:Circular
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Circular";
    rdfs:subClassOf aec:GenericShapeProperty.
aec:Clay
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Clay";
    rdfs:subClassOf aec:Material.
aec:ClosedState
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Closed state";
    rdfs:subClassOf aec:CavityBarrier.
aec:Column
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Column";
    rdfs:subClassOf aec:StructuralMember.
aec:Concrete
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Concrete";
    rdfs:subClassOf aec:Material.
aec:contains
    rdf:type owl:ObjectProperty;
    rdfs:comment
        "Direct containment or has-part relationship. Used to describe a physical containment, e.g. 'item is contained in a box'. Min cardinality 0 by default (can contain).";
    rdfs:domain owl:Thing;
    rdfs:label "contains";
    rdfs:range owl:Thing.
aec:Corner
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Corner";
    rdfs:subClassOf aec:DetailLocation.
aec:CurtainWallSystem
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Curtain wall system";
    rdfs:subClassOf aec:FacadeSystem.
aec:Curved
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Curved";
    rdfs:subClassOf aec:FacadeShape.
aec:CWFrameMember
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "CW frame member";
    rdfs:subClassOf aec:LinearComponent.
aec:CWFrameMemberProperties
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Specific properties of curtain wall frame members";
    rdfs:label "CW frame member properties".
aec:CWSystem
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "CW system";
    rdfs:subClassOf aec:CWFrameMemberProperties.
aec:DeadLoad
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Dead load";
    rdfs:subClassOf aec:StructuralProperties.
aec:DeadLoadBracket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Dead load bracket";
    rdfs:label "Dead load";
    rdfs:subClassOf aec:Bracket.
aec:Detail
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:comment "Detail drawing";
    rdfs:label "Detail";
    rdfs:subClassOf
        aec:DrawingType,
            [
                rdf:type owl:Restriction;
                owl:onClass aec:Orientation;
                owl:onProperty aec:hasProperty;
                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
            ].
aec:DetailLocation
a owl:Class; aec:labellableRoot "false"^^xsd:boolean; rdfs:label "Detail location".
aec:DGU
    rdf:type owl:Class;
    rdfs:comment "Double Glazing Unit";
    rdfs:label "DGU";
    rdfs:subClassOf aec:FacadeCladding.
aec:DoubleLaminated
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Double laminated";
    rdfs:subClassOf aec:GlazingProperties.
aec:DrawingElement
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment
        "Element depicted on a drawing. Contained by Layout. Can be a Facade system or Facade component.";
    rdfs:label "Drawing Element renamed";
    rdfs:subClassOf owl:Thing.
aec:DrawingOrientation
    rdf:type owl:Class;
    rdfs:label "DrawingOrientation";
    rdfs:subClassOf aec:Landscape, aec:Portrait.
aec:DrawingSheet
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Top-level container for a drawing. Contains Layout(s).";
    rdfs:label "Drawing sheet";
    rdfs:subClassOf
            [
                rdf:type owl:Restriction;
                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger;
                owl:onClass aec:RevisionTable;
                owl:onProperty aec:contains;
                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
            ],
            [
                rdf:type owl:Restriction;
                owl:minQualifiedCardinality "0"^^xsd:nonNegativeInteger;
                owl:onClass aec:Note;
                owl:onProperty aec:contains
            ],
            [
                rdf:type owl:Restriction;
                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
                owl:onClass aec:Layout;
                owl:onProperty aec:contains
            ],
            [
                rdf:type owl:Restriction;
                owl:onClass aec:DrawingOrientation;
                owl:onProperty aec:hasProperty;
                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
            ],
            [
                rdf:type owl:Restriction;
                owl:onProperty aec:contains;
                owl:someValuesFrom aec:FacadeComponent
            ].
aec:DrawingType
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Type of drawing view";
    rdfs:label "Drawing type";
    rdfs:subClassOf owl:Thing.
aec:Elevation
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:label "Elevation";
    rdfs:subClassOf aec:DrawingType.
aec:EPDM
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "EPDM";
    rdfs:subClassOf aec:Membrane.
aec:exampleImage
    rdf:type owl:AnnotationProperty;
    rdfs:comment
    "Links a class or concept to an example image illustrating it."@en;
    rdfs:label "example image"@en.
aec:Extruded
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Extruded";
    rdfs:subClassOf aec:FrameType.
aec:Fabricated
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Fabricated";
    rdfs:subClassOf aec:FrameType.
aec:FacadeCladding
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Facade cladding";
    rdfs:subClassOf aec:PanelComponent.
aec:FacadeComponent
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Component of a facade system ; a type of drawing element";
    rdfs:label "Facade component";
    rdfs:subClassOf aec:DrawingElement.
aec:FacadeSecondaryStructure
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Facade secondary structure";
    rdfs:subClassOf aec:LinearComponent.
aec:FacadeShape
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Facade shape";
    rdfs:subClassOf aec:GeometricProperties.
aec:FacadeSystem
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment
    "Facade system - part of support type ; a type of drawing element";
    rdfs:label "Facade system";
    rdfs:subClassOf
        aec:DrawingElement,
            [
                rdf:type owl:Restriction;
                owl:onProperty aec:contains;
                owl:someValuesFrom aec:FacadeComponent
            ].
aec:Faceted
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Faceted";
    rdfs:subClassOf aec:FacadeShape.
aec:FacingMaterial
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Can be standalone label - material used for facing";
    rdfs:label "Facing material".
aec:Fin
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Fin";
    rdfs:subClassOf aec:LinearComponent.
aec:FireCompartmentation
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Fire compartmentation";
    rdfs:subClassOf aec:Function.
aec:Firestop
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Firestop";
    rdfs:subClassOf aec:LinearComponent.
aec:Fixing
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Fixing";
    rdfs:subClassOf aec:PointComponent.
aec:Flipper
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Flipper";
    rdfs:subClassOf aec:Gasket.
aec:FrameType
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Frame type";
    rdfs:subClassOf aec:CWFrameMemberProperties.
aec:Function
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Function";
    rdfs:subClassOf aec:FunctionalProperties.
aec:FunctionalProperties
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "General property category";
    rdfs:label "Functional properties".
aec:Gasket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Gasket";
    rdfs:subClassOf aec:LinearComponent.
aec:GenericShapeProperty
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Generic shape property";
    rdfs:subClassOf aec:SectionProperties.
aec:GeometricProperties
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "General property category";
    rdfs:label "Geometric properties".
aec:Glass
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Glass";
    rdfs:subClassOf aec:Material.
aec:GlazingProperties
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Specific properties of glazing elements";
    rdfs:label "Glazing properties".
aec:GlazingRetention
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Glazing retention";
    rdfs:subClassOf aec:CWFrameMemberProperties.
aec:GRC
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "GRC";
    rdfs:subClassOf aec:PrecastSystem.
aec:hasProperty
    rdf:type owl:ObjectProperty;
    rdfs:comment
        "Subject is characterised by a property or quality, e.g. 'it has vertical alignment' or 'it is of colour blue'";
    rdfs:domain aec:Detail, owl:Thing;
    rdfs:label "hasProperty";
    rdfs:range aec:Orientation, owl:Thing.
aec:Head
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Head";
    rdfs:subClassOf aec:DetailLocation.
aec:HelpingHandBracket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Helping hand bracket";
    rdfs:label "Helping hand";
    rdfs:subClassOf aec:Bracket.
aec:HollowGasketShape
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Hollow gasket shape";
    rdfs:subClassOf aec:Gasket.
aec:Horizontal
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:label "Horizontal";
    rdfs:subClassOf aec:Orientation.
aec:Image
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:label "Image";
    rdfs:subClassOf aec:Note.
aec:Insulation
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Insulation";
    rdfs:subClassOf aec:PanelComponent.
aec:ISection
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "I-section";
    rdfs:subClassOf aec:SectionShape.
aec:labellableRoot
    rdf:type owl:AnnotationProperty;
    rdfs:comment
        "When true, this class can be used as a label by annotators (solid contour in diagram). When false, non-labellable (dashed contour).";
    rdfs:label "Labellable root";
    rdfs:range xsd:boolean.
aec:Laminated
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Laminated";
    rdfs:subClassOf aec:GlazingProperties.
aec:Landscape rdf:type owl:Class; aec:labellableRoot "true"^^xsd:boolean; rdfs:label "Landscape".

aec:Layout
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:comment
        "Drawing layout - contained by DrawingSheet. Contains DrawingElement(s), annotations, drawing type, and content.";
    rdfs:label "Layout";
    rdfs:subClassOf
            [
                rdf:type owl:Restriction;
                owl:minQualifiedCardinality 0;
                owl:onClass aec:DrawingElement;
                owl:onProperty aec:contains
            ],
            [
                rdf:type owl:Restriction;
                owl:onClass aec:DrawingType;
                owl:onProperty aec:hasProperty;
                owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger
            ].
aec:Legend
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:comment
        "A legend containing mapping information between symbols and a text signifier.";
    rdfs:label "Legend";
    rdfs:subClassOf aec:Metadata.
aec:LinearComponent
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Element category - linear facade component";
    rdfs:label "Linear component";
    rdfs:subClassOf aec:FacadeComponent.
aec:LinearStructuralComponent
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Linear structural component";
    rdfs:subClassOf aec:StructuralComponent.
aec:LocalisedPenetration
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Localised penetration";
    rdfs:subClassOf aec:PointComponent.
aec:Louvre
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Louvre";
    rdfs:subClassOf aec:LinearComponent.
aec:Masonry
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Masonry";
    rdfs:subClassOf aec:FacadeCladding.
aec:Material
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Material";
    rdfs:subClassOf aec:MaterialProperties.
aec:MaterialProperties
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "General property category";
    rdfs:label "Material properties".
aec:Membrane
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Membrane";
    rdfs:subClassOf aec:PanelComponent.
aec:Metadata
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Can be standalone label - drawing metadata";
    rdfs:label "Metadata";
    rdfs:subClassOf owl:Thing.
aec:Metal
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Metal";
    rdfs:subClassOf aec:Material.
aec:MineralWool
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Mineral wool";
    rdfs:subClassOf aec:Insulation.
aec:Monolithic
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Monolithic";
    rdfs:subClassOf aec:GlazingProperties.
aec:Mullion
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Mullion";
    rdfs:subClassOf aec:CWFrameMember.
aec:Note
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:label "Note";
    rdfs:subClassOf aec:Metadata.
aec:OGasket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "O-gasket";
    rdfs:subClassOf aec:HollowGasketShape.
aec:Ontology
    rdf:type owl:Ontology;
    rdfs:comment
        ;
    rdfs:label "AEC Drawing Ontology";
    owl:imports rdf:, rdfs:, xsd:, owl:, nam:, w:dano.
aec:OpenState
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Open state";
    rdfs:subClassOf aec:CavityBarrier.
aec:Orientation
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Can be standalone label - drawing orientation";
    rdfs:label "Detail Orientation";
    rdfs:subClassOf owl:Thing.
aec:OtherInsulation
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Other insulation";
    rdfs:subClassOf aec:Insulation.
aec:PanelComponent
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:comment "Element category - panel-type facade component";
    rdfs:label "Panel component";
    rdfs:subClassOf aec:FacadeComponent.
aec:PanelStructuralComponent
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "Panel structural component";
    rdfs:subClassOf aec:StructuralComponent.
aec:Perspective
    rdf:type owl:Class;
    aec:labellableRoot "true"^^xsd:boolean;
    rdfs:label "Perspective";
    rdfs:subClassOf aec:DrawingType.
aec:PGasket
    rdf:type owl:Class;
    aec:labellableRoot "false"^^xsd:boolean;
    rdfs:label "P-gasket";
    rdfs:subClassOf aec:HollowGasketShape.
aec:Plan
