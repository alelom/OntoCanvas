@prefix : <http://example.org/aec-drawing-ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

: a owl:Ontology .

:FacadeCladding rdf:type owl:Class ;
    rdfs:label "Facade cladding" ;
    rdfs:comment "A facade cladding element" ;
    :labellableRoot "false"^^xsd:boolean .

:DrawingElement rdf:type owl:Class ;
    rdfs:label "Drawing element" ;
    rdfs:comment "Element depicted in a drawing" .

:Metadata rdf:type owl:Class ;
    rdfs:label "Metadata" ;
    :labellableRoot "false"^^xsd:boolean .

:Note rdf:type owl:Class ;
    rdfs:label "Note" ;
    :labellableRoot "true"^^xsd:boolean .

:FacadeSystem rdf:type owl:Class ;
    rdfs:label "Facade system" ;
    rdfs:subClassOf :DrawingElement .

:Layout rdf:type owl:Class ;
    rdfs:label "Layout" .

:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:comment "A containment relationship" ;
    rdfs:domain :Layout ;
    rdfs:range :DrawingElement .

:hasFunction a owl:ObjectProperty ;
    rdfs:label "has function" ;
    rdfs:domain :FacadeCladding ;
    rdfs:range :Function .

:Function rdf:type owl:Class ;
    rdfs:label "Function" .

# Annotation properties
:labellableRoot a owl:AnnotationProperty ;
    rdfs:label "labellable root" ;
    rdfs:range xsd:boolean .

:hasCardinality a owl:AnnotationProperty ;
    rdfs:label "has cardinality" ;
    rdfs:range xsd:boolean .

:FacadeCladding rdfs:subClassOf :DrawingElement .
:Layout :contains :FacadeCladding .

# Add a restriction to test blank node inlining
:SomeClass rdf:type owl:Class ;
    rdfs:label "Some class" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty :contains ;
        owl:someValuesFrom :DrawingElement
    ] .

