@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://example.org/test#> .

<#Ontology> rdf:type owl:Ontology ;
    rdfs:comment "Test ontology with base notation" .

<#TestClass> rdf:type owl:Class ;
    rdfs:label "Test Class" ;
    rdfs:subClassOf <#ParentClass> .

<#ParentClass> rdf:type owl:Class ;
    rdfs:label "Parent Class" .

<#hasProperty> rdf:type owl:ObjectProperty ;
    rdfs:domain <#TestClass> ;
    rdfs:range <#ParentClass> .
