@prefix : <http://example.org/test#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Class1 rdf:type owl:Class ;
    rdfs:label "Class 1" ;
    rdfs:comment "First class" ;
    :labellableRoot true .

:Class2 rdf:type owl:Class ;
    rdfs:subClassOf :Class1 ;
    rdfs:label "Class 2" ;
    rdfs:subClassOf 
        [ rdf:type owl:Restriction ;
          owl:onProperty :hasProperty ;
          owl:onClass :OtherClass ] .

:Class3 rdf:type owl:Class ;
    rdfs:label "Class 3" ;
    rdfs:comment "Third class" ;
    :labellableRoot false .
