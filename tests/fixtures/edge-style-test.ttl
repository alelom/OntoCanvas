@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix : <http://example.org/edge-style-test#> .

:ClassA a owl:Class ;
    rdfs:label "Class A" .

:ClassB a owl:Class ;
    rdfs:label "Class B" .

:ClassC a owl:Class ;
    rdfs:label "Class C" .

:hasProperty a owl:ObjectProperty ;
    rdfs:label "has property" ;
    rdfs:domain :ClassA ;
    rdfs:range :ClassB .

:contains a owl:ObjectProperty ;
    rdfs:label "contains" ;
    rdfs:domain :ClassB ;
    rdfs:range :ClassC .

:ClassA rdfs:subClassOf :ClassB .

:ClassA :hasProperty :ClassB .
:ClassB :contains :ClassC .
