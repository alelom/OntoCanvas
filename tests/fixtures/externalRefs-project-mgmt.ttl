@prefix :      <http://example.org/project-mgmt#> .
@prefix pm:    <http://example.org/project-mgmt#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/project-mgmt>
    rdf:type owl:Ontology .

pm:Person       rdf:type owl:Class ; rdfs:label "Person"@en .
pm:Project      rdf:type owl:Class ; rdfs:label "Project"@en .
pm:Organisation rdf:type owl:Class ; rdfs:label "Organisation"@en .
