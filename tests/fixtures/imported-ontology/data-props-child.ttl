@prefix : <http://example.org/data-extended#> .
@prefix dpbase: <http://example.org/data-base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/data-extended> rdf:type owl:Ontology ;
    rdfs:label "Data Properties Extended" ;
    owl:imports <http://example.org/data-base> .

:ExtendedEntity rdf:type owl:Class ;
    rdfs:label "Extended Entity" ;
    rdfs:subClassOf dpbase:BaseEntity ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty dpbase:identifier ;
        owl:minCardinality 1
    ] ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty dpbase:createdDate ;
        owl:onDataRange xsd:dateTime
    ] .
