@prefix : <http://example.org/data-base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/data-base> rdf:type owl:Ontology ;
    rdfs:label "Data Properties Base" ;
    rdfs:comment "Parent ontology defining data properties" .

:BaseEntity rdf:type owl:Class ;
    rdfs:label "Base Entity" .

:identifier rdf:type owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:domain :BaseEntity ;
    rdfs:range xsd:string .

:createdDate rdf:type owl:DatatypeProperty ;
    rdfs:label "created date" ;
    rdfs:domain :BaseEntity ;
    rdfs:range xsd:dateTime ;
    rdfs:isDefinedBy <http://example.org/data-base> .
