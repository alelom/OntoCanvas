@prefix : <http://example.org/object-specialized#> .
@prefix extended: <http://example.org/object-extended#> .
@prefix base: <http://example.org/object-base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/object-specialized> rdf:type owl:Ontology ;
    rdfs:label "Object Properties Specialized" ;
    owl:imports <http://example.org/object-extended> .

:SpecializedGrandchildClass rdf:type owl:Class ;
    rdfs:label "Specialized Grandchild Class" ;
    rdfs:subClassOf extended:ChildClass .
