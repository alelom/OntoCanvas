@prefix : <http://example.org/object-extended#> .
@prefix base: <http://example.org/object-base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<http://example.org/object-extended> rdf:type owl:Ontology ;
    rdfs:label "Object Properties Extended" ;
    owl:imports <http://example.org/object-base> .

:ChildClassA rdf:type owl:Class ;
    rdfs:label "Child Class A" ;
    rdfs:subClassOf [
        rdf:type owl:Restriction ;
        owl:onProperty base:connectsTo ;
        owl:someValuesFrom :ChildClassB
    ] .

:ChildClassB rdf:type owl:Class ;
    rdfs:label "Child Class B" .