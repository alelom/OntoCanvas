@prefix : <http://example.org/specialized-extended#> .
@prefix extended: <http://example.org/extended#> .
@prefix base: <http://example.org/base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/specialized-extended> rdf:type owl:Ontology ;
    rdfs:label "Specialized Extended Ontology" ;
    owl:imports <http://example.org/extended> .

:SpecializedClass rdf:type owl:Class ;
    rdfs:label "Specialized Class" ;
    rdfs:subClassOf extended:ExtendedClass ;
    base:name "Specialized Instance" .
