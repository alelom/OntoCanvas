@prefix : <http://example.org/extended#> .
@prefix base: <http://example.org/base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/extended> rdf:type owl:Ontology ;
    rdfs:label "Extended Ontology" ;
    owl:imports <http://example.org/base> .

:ExtendedClass rdf:type owl:Class ;
    rdfs:label "Extended Class" ;
    rdfs:subClassOf base:BaseClass .

:Instance1 rdf:type :ExtendedClass ;
    base:name "Test Instance" .
