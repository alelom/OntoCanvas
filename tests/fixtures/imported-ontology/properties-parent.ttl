@prefix : <http://example.org/base#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/base> rdf:type owl:Ontology ;
    rdfs:label "Base Ontology" ;
    rdfs:comment "Parent ontology defining object and data properties" .

:BaseClass rdf:type owl:Class ;
    rdfs:label "Base Class" .

:hasProperty rdf:type owl:ObjectProperty ;
    rdfs:label "has property" ;
    rdfs:domain :BaseClass ;
    rdfs:range :BaseClass ;
    rdfs:isDefinedBy <http://example.org/base> .

:name rdf:type owl:DatatypeProperty ;
    rdfs:label "name" ;
    rdfs:domain :BaseClass ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy <http://example.org/base> .
