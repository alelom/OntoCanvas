@prefix : <http://example.org#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

:ClassWithList rdf:type owl:Class ;
    rdfs:label "Class with list" ;
    :hasItems ( :item1 :item2 :item3 ) .

:ClassWithEmptyList rdf:type owl:Class ;
    rdfs:label "Class with empty list" ;
    :hasItems () .

:ClassWithNestedList rdf:type owl:Class ;
    rdfs:label "Class with nested list" ;
    :hasItems ( ( :item1 :item2 ) ( :item3 :item4 ) ) .
